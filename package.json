{
  "name": "synthetic-test-fabric",
  "version": "0.3.0",
  "description": "Generic engine for autonomous synthetic test loops: simulation → browser flows → scoring → feedback",
  "keywords": [
    "testing",
    "qa",
    "automation",
    "synthetic",
    "playwright",
    "browser-testing",
    "simulation",
    "test-generation",
    "typescript"
  ],
  "author": "kaneshir",
  "homepage": "https://github.com/kaneshir/synthetic-test-fabric",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaneshir/synthetic-test-fabric"
  },
  "bugs": {
    "url": "https://github.com/kaneshir/synthetic-test-fabric/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fab": "dist/cli/fab.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "check:boundary": "npx tsx scripts/check-boundary.ts",
    "check:package-surface": "npx tsx scripts/check-package-surface.ts",
    "check:demo": "npm run build && tsc --project tsconfig.demo.json --noEmit",
    "check:fixtures": "tsc --project tsconfig.fixtures.json --noEmit",
    "demo": "npx tsx demo/run.ts",
    "demo:install": "npx playwright install --with-deps chromium",
    "benchmark": "npx tsx demo/benchmark.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@kaneshir/lisa-mcp": "^1.0.1",
    "@playwright/test": "^1.44.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "openai": "^4.98.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "docs/prerequisites.md",
    "docs/testability-standard.md",
    "docs/overview.md",
    "docs/example-walkthrough.md",
    "docs/quickstart.md",
    "docs/architecture.md",
    "docs/adapter-contract.md",
    "docs/schema-reference.md",
    "docs/orchestrator-reference.md",
    "docs/phases-detailed.md",
    "docs/wiring-non-js-backends.md",
    "docs/env-vars.md",
    "docs/failure-recovery.md",
    "docs/demo-limitations.md",
    "docs/package-exports.md",
    "docs/run-root-contract.md",
    "docs/persona-yaml-reference.md",
    "docs/lisa-mcp.md",
    "docs/for-qa-engineers.md",
    "docs/executive-brief.md",
    "docs/value-proposition.md",
    "docs/adapter-testing.md",
    "docs/fixtures/",
    "demo/",
    "!demo/app/seed-data.js",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "@google/generative-ai": ">=0.1.0",
    "@kaneshir/lisa-mcp": "^1.0.1",
    "@playwright/test": "^1.44.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "@kaneshir/lisa-mcp": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
